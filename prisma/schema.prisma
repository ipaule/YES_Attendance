generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  username  String   @unique
  password  String
  role      String   @default("LEADER") // PASTOR, EXECUTIVE, LEADER
  groupId   String?
  group     Group?   @relation(fields: [groupId], references: [id])
  teamId    String?  @unique
  team      Team?    @relation("LeaderOfTeam")
  createdAt DateTime @default(now())
}

model Group {
  id    String @id @default(cuid())
  name  String @unique
  order Int    @default(0)
  users User[]
  teams Team[]
}

model Team {
  id        String   @id @default(cuid())
  name      String
  groupId   String
  group     Group    @relation(fields: [groupId], references: [id])
  leaderId  String?  @unique
  leader    User?    @relation("LeaderOfTeam", fields: [leaderId], references: [id])
  members   Member[]
  dates     AttendanceDate[]
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  @@unique([name, groupId])
}

model Member {
  id          String       @id @default(cuid())
  name        String
  gender      String       // MALE, FEMALE
  birthYear   String       @default("")
  teamId      String
  team        Team         @relation(fields: [teamId], references: [id], onDelete: Cascade)
  attendances Attendance[]
  order       Int          @default(0)
  createdAt   DateTime     @default(now())
}

model AttendanceDate {
  id          String       @id @default(cuid())
  date        DateTime
  label       String
  teamId      String
  team        Team         @relation(fields: [teamId], references: [id], onDelete: Cascade)
  order       Int          @default(0)
  attendances Attendance[]
  createdAt   DateTime     @default(now())

  @@unique([date, teamId])
}

model GlobalDate {
  id    String   @id @default(cuid())
  date  DateTime @unique
  label String
  order Int      @default(0)
}

model TermHistory {
  id        String   @id @default(cuid())
  name      String
  data      String   // JSON snapshot of all term data
  createdAt DateTime @default(now())
}

model ShalomMember {
  id        String   @id @default(cuid())
  name      String
  gender    String   @default("")
  birthYear String   @default("")
  phone     String   @default("")
  visitDate String   @default("")
  inviter   String   @default("")
  order     Int      @default(0)
  leader    String   @default("")
  note      String   @default("")
  status    String   @default("방문") // 방문, 등록, 졸업
  createdAt DateTime @default(now())
}

model RosterMember {
  id        String   @id @default(cuid())
  name      String
  gender    String   @default("")
  birthYear String   @default("")
  groupName String   @default("")
  teamName  String   @default("")
  ministry  String   @default("")
  note      String   @default("")
  order     Int      @default(0)
  createdAt DateTime @default(now())
}

model Link {
  id        String   @id @default(cuid())
  title     String
  url       String
  editedBy  String   @default("")
  order     Int      @default(0)
  createdAt DateTime @default(now())
}

model ShalomHistory {
  id        String   @id @default(cuid())
  name      String
  data      String   // JSON array of ShalomMember records
  createdAt DateTime @default(now())
}

model Attendance {
  id               String         @id @default(cuid())
  memberId         String
  member           Member         @relation(fields: [memberId], references: [id], onDelete: Cascade)
  attendanceDateId String
  attendanceDate   AttendanceDate @relation(fields: [attendanceDateId], references: [id], onDelete: Cascade)
  status           String         @default("HERE") // HERE, ABSENT, AWR
  awrReason        String?

  @@unique([memberId, attendanceDateId])
}
